# Your EVM private key for USDC payments via APINow (x402 protocol)
# Get one from any EVM wallet (MetaMask, Coinbase Wallet, etc.)
# Fund it with USDC on Base for API payments
PRIVATE_KEY=0x...

# Optional: override the default model
# OLLAMA_MODEL=gemma4

# APINow pre-router: local LLM decides if the message is really an external API request (default: on)
# ROUTER_INTENT_MODEL=gemma4
# ROUTER_DISABLE_LLM_INTENT=1

# Optional: Telegram bot token (get from @BotFather)
# When set, the app runs as a Telegram bot instead of CLI
# TELEGRAM_BOT_TOKEN=
